# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GROQ_API_KEY: Required to use Groq's LLM API (e.g. LLaMA 3). Server-side only.
GROQ_API_KEY=

# VITE_GOOGLE_CLIENT_ID: OAuth 2.0 "Web application" Client ID used by Google
# Identity Services (client-side) to sign in and sync Google Calendar.
# Get it at https://console.cloud.google.com/apis/credentials and add your app's
# origin (e.g. http://localhost:3000 and your Netlify URL) to "Authorized
# JavaScript origins". This value is public (shipped to the browser).
VITE_GOOGLE_CLIENT_ID=

# APIFY_API_TOKEN: Required for the "Analizar redes" button (fetches real
# public Instagram profile data via Apify before summarizing it with Groq).
# Get a free token at https://console.apify.com/settings/integrations.
# Server-side only.
APIFY_API_TOKEN=

# APIFY_ACTOR_ID: Optional override for the Apify actor used to scrape
# Instagram profiles. Defaults to the public "apify~instagram-profile-scraper"
# actor if unset.
APIFY_ACTOR_ID=
